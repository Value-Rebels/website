---
import { getCollection } from 'astro:content';
import { getLangFromUrl, t } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const allServices = await getCollection('services');
const services = allServices
  .filter(s => s.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);
---
<section id="services" class="py-24 bg-rebel-dark">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl font-bold text-white mb-4">
      <span class="border-b-4 border-rebel-red pb-2">{t(lang, 'services.title')}</span>
    </h2>
    <p class="text-rebel-text-muted max-w-2xl mb-16 text-lg leading-relaxed">
      {t(lang, 'services.intro')}
    </p>

    <div class="grid md:grid-cols-3 gap-8">
      {services.map(service => (
        <div class="bg-rebel-gray rounded-lg p-8 hover:bg-rebel-gray-light transition-colors group">
          <div class="w-12 h-12 bg-rebel-red/20 rounded-lg flex items-center justify-center mb-6 group-hover:bg-rebel-red/30 transition-colors">
            <svg class="w-6 h-6 text-rebel-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-4">{service.data.title}</h3>
          <p class="text-rebel-text-muted leading-relaxed">{service.data.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
