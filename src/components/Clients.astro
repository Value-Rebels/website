---
import { getCollection } from 'astro:content';
import { getLangFromUrl, t } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const clientEntries = await getCollection('clients');
const clientData = clientEntries[0]?.data.clients ?? [];
---
<section class="py-16 bg-rebel-darker">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-2xl font-bold text-white mb-10 text-center">
      {t(lang, 'clients.title')}
    </h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-7 gap-8 items-center justify-items-center opacity-70">
      {clientData.map(client => (
        <img
          src={client.logo}
          alt={client.name}
          class="h-8 w-auto max-w-[120px] object-contain hover:opacity-100 transition-opacity"
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>
