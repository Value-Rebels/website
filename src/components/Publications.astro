---
import { getCollection } from 'astro:content';
import { getLangFromUrl, t, localizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const allVideos = await getCollection('videos');
const videos = allVideos.sort((a, b) => a.data.order - b.data.order);

const allArticles = await getCollection('articles');
const articles = allArticles
  .filter(a => a.data.lang === lang)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<section id="publications" class="py-24 bg-rebel-dark">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl font-bold text-white mb-4">
      <span class="border-b-4 border-rebel-red pb-2">{t(lang, 'publications.title')}</span>
    </h2>
    <p class="text-rebel-text-muted max-w-3xl mb-16 text-lg leading-relaxed">
      {t(lang, 'publications.intro')}
    </p>

    <!-- Videos -->
    <h3 class="text-sm font-bold tracking-widest uppercase text-rebel-red mb-8">
      {t(lang, 'publications.videos')}
    </h3>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
      {videos.map(video => (
        <a
          href={`https://www.youtube.com/watch?v=${video.data.youtubeId}`}
          target="_blank"
          rel="noopener noreferrer"
          class="group"
        >
          <div class="aspect-video bg-rebel-gray rounded-lg overflow-hidden mb-4 relative">
            <img
              src={`https://img.youtube.com/vi/${video.data.youtubeId}/maxresdefault.jpg`}
              alt={video.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
            <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/20 transition-colors">
              <svg class="w-16 h-16 text-white/80 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
          <h4 class="text-lg font-bold text-white group-hover:text-rebel-red transition-colors">{video.data.title}</h4>
          <p class="text-rebel-text-muted text-sm mt-2">{video.data.description}</p>
        </a>
      ))}
    </div>

    <!-- Articles -->
    <h3 class="text-sm font-bold tracking-widest uppercase text-rebel-red mb-8">
      {t(lang, 'publications.articles')}
    </h3>
    <div class="grid md:grid-cols-2 gap-8">
      {articles.map(article => (
        <a
          href={localizedPath(lang, `/articles/${article.data.slug}`)}
          class="group bg-rebel-gray rounded-lg overflow-hidden hover:bg-rebel-gray-light transition-colors"
        >
          <div class="p-8">
            <h4 class="text-lg font-bold text-white group-hover:text-rebel-red transition-colors mb-3">
              {article.data.title}
            </h4>
            <p class="text-rebel-text-muted text-sm mb-4">{article.data.excerpt}</p>
            <span class="text-rebel-red text-sm font-medium">
              {article.data.readingTime} {t(lang, 'publications.minRead')}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
